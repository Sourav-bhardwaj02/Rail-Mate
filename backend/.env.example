# Environment variables for RailMate AI Backend
# Copy this file to .env and fill in the values

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/railmate_db"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS - comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# AI (optional - for real AI integration)
AI_API_KEY=your-ai-api-key-here
AI_MAX_TOKENS=2048

# Upload
UPLOAD_MAX_SIZE_MB=5

# Email SMTP Setup for SOS (Gmail App Passwords recommended)
EMAIL_USER=souravbhardwaj2005@gmail.com
EMAIL_PASS=your_gmail_app_password
